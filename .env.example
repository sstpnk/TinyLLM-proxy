# =============================================================================
# TinyLLM — Environment variables
# =============================================================================
# Copy this file to .env (or set the vars directly in Docker / systemd).
# DO NOT commit actual secrets to the repository.
# =============================================================================

# Comma-separated list of API keys that clients use to talk to TinyLLM.
TINYLLM_API_KEYS=sk-tinyllm-master-key

# API keys for upstream providers (the values are examples — replace them).
OPENCODE_ZEN_API_KEY=sk-zen-placeholder
OPENROUTER_API_KEY=sk-or-placeholder
ZAI_API_KEY=sk-zai-placeholder
